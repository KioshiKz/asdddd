<Window x:Class="OiTech.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OiTech · Diploma System" Height="850" Width="1250"
        Background="{DynamicResource BgDarkBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,35">
                    <Border Width="42" Height="42" Background="{StaticResource AccentGradient}" CornerRadius="10"
                            HorizontalAlignment="Left" Margin="0,0,0,12">
                        <TextBlock Text="O" Foreground="White" FontWeight="Bold" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="OiTech" Foreground="{DynamicResource TextWhiteBrush}"
                               FontSize="19" FontWeight="Bold"/>
                    <TextBlock Text="DIPLOMA SYSTEM" Foreground="{DynamicResource TextDimBrush}"
                               FontSize="10" FontWeight="Bold" Opacity="0.7"/>
                </StackPanel>

                <!-- Bottom controls: theme + language -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="20,4,20,4"/>

                    <Button Style="{StaticResource SidebarButton}" Click="ToggleTheme">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ThemeIcon" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="ThemeLabel" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}" Click="ToggleLang">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="LangLabel" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_Home">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavHome}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_Students">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavStudents}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_Import">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavImport}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_ImportWord">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavImportWord}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_Template">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavTemplates}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}" Click="Nav_Reports">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource NavReports}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Column="1" Background="{DynamicResource BgContentBrush}">
            <!-- Dashboard -->
            <ScrollViewer x:Name="DashboardPanel" VerticalScrollBarVisibility="Auto">
                <Border Padding="30">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DashboardTitle}"
                                   Foreground="{DynamicResource TextWhiteBrush}"
                                   FontSize="22" FontWeight="ExtraBold" Margin="0,0,0,25"/>

                        <Border CornerRadius="15" Margin="0,0,0,25" BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Background="{DynamicResource WelcomeBannerBrush}">
                            <Border Padding="25">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource WelcomeTitle}"
                                               Foreground="{DynamicResource TextWhiteBrush}"
                                               FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text="{DynamicResource WelcomeSubtitle}"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               FontSize="14" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Stats -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource StatsStudents}"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="StudentsCountText" Text="0"
                                                   Foreground="{DynamicResource TextWhiteBrush}"
                                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="28" Foreground="{StaticResource AccentBlueBrush}" Opacity="0.6"/>
                                </DockPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource StatCard}">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource StatsSubjects}"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="SubjectsCountText" Text="0"
                                                   Foreground="{DynamicResource TextWhiteBrush}"
                                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="28" Foreground="{StaticResource AccentPurpleBrush}" Opacity="0.6"/>
                                </DockPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0">
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource StatsPrinted}"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="PrintedCountText" Text="0"
                                                   Foreground="{DynamicResource TextWhiteBrush}"
                                                   FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="&#xE749;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="28" Foreground="{StaticResource AccentGreenBrush}" Opacity="0.6"/>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="{DynamicResource ActionLogTitle}"
                                   Foreground="{DynamicResource TextWhiteBrush}"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Opacity="0.8"/>
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <StackPanel x:Name="ActionsPanel" Margin="0,5"/>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Dynamic page content -->
            <ContentControl x:Name="MainContent" Visibility="Collapsed"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <ContentControl.RenderTransform>
                    <TranslateTransform Y="0"/>
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
