<UserControl x:Class="OiTech.App.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDarkBrush}">
    <Border Padding="30">
        <StackPanel>
            <TextBlock Text="{DynamicResource ReportsTitle}"
                       Foreground="{DynamicResource TextWhiteBrush}"
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Summary card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ReportsSummaryTitle}"
                               Foreground="{DynamicResource TextWhiteBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ReportsTotalStudents}"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="14" Margin="0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TotalStudents"
                                   Foreground="{DynamicResource TextWhiteBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ReportsSubjects}"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="14" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalSubjects"
                                   Foreground="{DynamicResource TextWhiteBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource ReportsAvgGrade}"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="14" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AvgGrade"
                                   Foreground="{StaticResource AccentBlueBrush}" FontSize="14" FontWeight="Bold" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource ReportsPrinted}"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="14" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PrintedCount"
                                   Foreground="{DynamicResource TextWhiteBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Grades breakdown -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ReportsGradesBySubject}"
                               Foreground="{DynamicResource TextWhiteBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <StackPanel x:Name="SubjectBarsPanel"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
