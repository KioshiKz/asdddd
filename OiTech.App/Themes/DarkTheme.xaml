<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BgDarkBrush"          Color="#0D1117"/>
    <SolidColorBrush x:Key="BgCardBrush"           Color="#161B22"/>
    <SolidColorBrush x:Key="BgSidebarBrush"        Color="#0D1117"/>
    <SolidColorBrush x:Key="BgHoverBrush"          Color="#1F2937"/>
    <SolidColorBrush x:Key="BgContentBrush"        Color="#0F1218"/>
    <SolidColorBrush x:Key="BorderBrush"           Color="#30363D"/>
    <SolidColorBrush x:Key="TextWhiteBrush"        Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextDimBrush"          Color="#8B949E"/>
    <SolidColorBrush x:Key="DataGridRowBrush"      Color="#161B22"/>
    <SolidColorBrush x:Key="DataGridAltRowBrush"   Color="#1C2230"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush"   Color="#0D1117"/>
    <SolidColorBrush x:Key="TextBoxBgBrush"        Color="#0D1117"/>
    <SolidColorBrush x:Key="CaretBrush"            Color="White"/>

    <LinearGradientBrush x:Key="WelcomeBannerBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1C212B" Offset="0"/>
        <GradientStop Color="#161B22" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
